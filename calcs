// =====================
// SCREEN SYSTEM
// =====================
function showScreen(id, direction) {
  document.querySelectorAll('.kys-screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById(id);
  if (el) { el.classList.add('active'); el.scrollIntoView({behavior:'instant'}); }
  currentScreen = id;

  const idx = screenOrder.indexOf(id);
  const header = document.getElementById('kysHeader');
  const prog = document.getElementById('kysProgressBar');

  if (id === 'intro-screen') {
    header.classList.remove('show');
    prog.classList.remove('show');
  } else {
    header.classList.add('show');
    prog.classList.add('show');
    document.querySelectorAll('.step-dot').forEach((d,i) => {
      d.classList.remove('active','done');
      if (i < idx - 1) d.classList.add('done');
      else if (i === idx - 1) d.classList.add('active');
    });
    const pct = Math.round(((idx) / (screenOrder.length - 1)) * 100);
    document.getElementById('kysProgressFill').style.width = pct + '%';
  }

  if (id === 'individual-screen') liveUpdate();
}

function triggerWipe(cb) {
  const wipe = document.getElementById('wipeOverlay');
  wipe.classList.add('animating');
  setTimeout(cb, 300);
  setTimeout(() => wipe.classList.remove('animating'), 700);
}

function createRipple(e) {
  const btn = e.currentTarget || e.target;
  if (!btn || !btn.getBoundingClientRect) return;
  const r = document.createElement('span');
  r.className = 'ripple-effect';
  const rect = btn.getBoundingClientRect();
  const size = Math.max(rect.width, rect.height) * 1.4;
  r.style.cssText = `width:${size}px;height:${size}px;left:${e.clientX-rect.left-size/2}px;top:${e.clientY-rect.top-size/2}px;`;
  btn.appendChild(r);
  setTimeout(() => r.remove(), 600);
}

function goBack() {
  const idx = screenOrder.indexOf(currentScreen);
  if (idx > 0) triggerWipe(() => showScreen(screenOrder[idx - 1]));
}

// =====================
// FLOW
// =====================
function goToCategory(e) {
  createRipple(e);
  triggerWipe(() => showScreen('category-screen'));
}

function selectCategory(type, e) {
  appState.category = type;
  document.querySelectorAll('.kys-profile-card').forEach(c => c.classList.remove('selected'));
  e.currentTarget.classList.add('selected');
  createRipple(e);
  setTimeout(() => triggerWipe(() => showScreen('individual-screen')), 180);
}

function setRegime(r) {
  appState.regime = r;
  document.getElementById('regimeOld').classList.toggle('active', r === 'old');
  document.getElementById('regimeNew').classList.toggle('active', r === 'new');
  document.getElementById('regimeBadge').innerText = r === 'new' ? 'New Regime' : 'Old Regime';

  // Toggle 80C/80D visibility based on regime
  const expandable = document.getElementById('savingsExpandable');
  const d80c = document.getElementById('deduction80c');
  const d80d = document.getElementById('deduction80d');
  const hra  = document.getElementById('deductionHra');
  if (r === 'new') {
    // Deductions not allowed in new regime
    [d80c, d80d, hra].forEach(el => { el.value = 0; el.disabled = true; el.style.opacity = '0.4'; });
    appState.deductions = {'80c':0,'80d':0,'hra':0};
  } else {
    [d80c, d80d, hra].forEach(el => { el.disabled = false; el.style.opacity = '1'; });
  }
  liveUpdate();
}

function goToLead(e) {
  if (e) createRipple(e);
  const r = taxEngine.calculate({
    salary: appState.salary, regime: appState.regime,
    deductions: appState.deductions, fy: appState.fy
  });
  lastResult = r;
  document.getElementById('leadTaxDisplay').innerText = '₹' + r.totalTax.toLocaleString('en-IN');
  document.getElementById('leadSavingsDisplay').innerText = r.potentialSaving > 0 ? '₹' + r.potentialSaving.toLocaleString('en-IN') : 'Optimized';
  document.getElementById('leadRegimeDisplay').innerText = appState.regime === 'new' ? 'New Regime (Default)' : 'Old Regime';
  triggerWipe(() => showScreen('lead-screen'));
}

function submitLead(e) {
  if (e) createRipple(e);
  appState.name = document.getElementById('leadName')?.value || 'Taxpayer';
  appState.phone = document.getElementById('leadPhone')?.value || '';
  appState.email = document.getElementById('leadEmail')?.value || '';
  const result = lastResult || taxEngine.calculate({ salary: appState.salary, regime: appState.regime, deductions: appState.deductions });
  buildResultDashboard(result);
  triggerWipe(() => showScreen('result-screen'));
}

// =====================
// LIVE UPDATE ENGINE
// =====================
function liveUpdate() {
  const salary = parseFloat(document.getElementById('salaryInput')?.value) || 0;
  const tds = document.getElementById('tdsSelect')?.value || 'yes';
  const ded80c = parseFloat(document.getElementById('deduction80c')?.value) || 0;
  const ded80d = parseFloat(document.getElementById('deduction80d')?.value) || 0;
  const hra   = parseFloat(document.getElementById('deductionHra')?.value) || 0;

  appState.salary = salary;
  appState.tds = tds;
  appState.deductions = { '80c': Math.min(ded80c,150000), '80d': Math.min(ded80d,25000), 'hra': hra };

  const result = taxEngine.calculate({
    salary, regime: appState.regime, deductions: appState.deductions, fy: appState.fy
  });
  lastResult = result;

  // Update preview
  const estTax = result.totalTax;
  const el = document.getElementById('estimatedTaxDisplay');
  const prevVal = el.getAttribute('data-val') || '0';
  if (prevVal !== String(estTax)) {
    el.classList.remove('animate');
    void el.offsetWidth;
    el.classList.add('animate');
    el.setAttribute('data-val', estTax);
  }
  el.innerText = '₹' + estTax.toLocaleString('en-IN');

  const optEl = document.getElementById('optimizedTaxDisplay');
  if (result.potentialSaving > 0) {
    optEl.innerText = '↓ Save ₹' + result.potentialSaving.toLocaleString('en-IN');
    optEl.classList.add('show');
  } else {
    optEl.classList.remove('show');
  }
  document.getElementById('taxRangeDisplay').innerText = 'FY 2025–26 • ' + result.slab + ' slab';

  updateInsight(result);
  updateRecommendations(result);
  updateSimulator(result);
}

function updateInsight(result) {
  const text = document.getElementById('insightText');
  const salary = appState.salary;
  if (!salary) {
    text.innerText = 'Enter your income details above to see personalized tax analysis.';
    return;
  }
  if (salary <= (appState.regime === 'new' ? 700000 : 500000)) {
    text.innerText = 'Good news — your income falls within the tax-free slab after the Section 87A rebate. However, filing an ITR is recommended for financial record-keeping and refund claims.';
  } else if (result.incomeTax > 0 && appState.regime === 'new' && salary > 700000) {
    const diff = result.totalTax;
    text.innerText = `As per the new tax regime for FY 2025–26, your estimated liability is ₹${diff.toLocaleString('en-IN')}. The new regime offers lower rates but no major deductions — compare with old regime if you have significant investments.`;
  } else if (appState.regime === 'old' && appState.deductions['80c'] < 150000) {
    text.innerText = `You are leaving tax deductions on the table. Maximizing 80C (₹1,50,000) and 80D (₹25,000) could reduce your taxable income by ₹${(150000 - appState.deductions['80c'] + 25000 - appState.deductions['80d']).toLocaleString('en-IN')}.`;
  } else {
    text.innerText = `As per applicable provisions of the Income Tax Act for FY 2025–26, your estimated liability is ₹${result.totalTax.toLocaleString('en-IN')}. You are in the ${result.slab} effective slab.`;
  }
}

function updateRecommendations(result) {
  const feed = document.getElementById('recommendationFeed');
  let html = '';
  const sal = appState.salary;
  const d80c = appState.deductions['80c'];
  const d80d = appState.deductions['80d'];

  if (sal > 700000 && d80c < 150000 && appState.regime === 'old') {
    const savings = Math.min(150000 - d80c, sal) * 0.3;
    html += nudge('success', checkIcon(), `💚 Invest ₹${(150000-d80c).toLocaleString('en-IN')} more in 80C (EPF/PPF/ELSS) to save up to ₹${Math.round(savings).toLocaleString('en-IN')} in tax.`);
  }
  if (sal > 500000 && d80d < 25000 && appState.regime === 'old') {
    html += nudge('info', infoIcon(), `🔵 Health insurance premium up to ₹25,000 is deductible under Section 80D — you have ₹${(25000-d80d).toLocaleString('en-IN')} remaining.`);
  }
  if (appState.tds === 'no' && sal > 500000) {
    html += nudge('warning', warnIcon(), `⚠️ No TDS deducted. You may be required to pay advance tax in quarterly installments to avoid interest under Section 234B/234C.`);
  }
  if (appState.regime === 'new' && sal > 900000 && result.potentialSaving > 0) {
    html += nudge('info', infoIcon(), `💡 Switching to the old regime with full deductions could save you ₹${result.potentialSaving.toLocaleString('en-IN')}. Our CA team can run a detailed comparison.`);
  }
  feed.innerHTML = html;
}

function nudge(type, icon, text) {
  return `<div class="kys-nudge-card ${type}">${icon}<div>${text}</div></div>`;
}
function checkIcon() { return `<svg class="nudge-success-icon" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>`; }
function infoIcon() { return `<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>`; }
function warnIcon() { return `<svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`; }

function updateSimulator(result) {
  const sim = document.getElementById('savingsSimulator');
  if (result.potentialSaving > 0 && appState.salary > 600000) {
    sim.style.display = 'block';
    let tip = '';
    if (appState.regime === 'new') {
      tip = `Switching to old regime with ₹1,50,000 in 80C + ₹25,000 in 80D could save you ₹${result.potentialSaving.toLocaleString('en-IN')} annually.`;
    } else {
      const rem80c = Math.max(150000 - appState.deductions['80c'], 0);
      if (rem80c > 0) tip = `Invest ₹${rem80c.toLocaleString('en-IN')} more in 80C (PPF/ELSS/LIC) → potential tax saving of ₹${result.potentialSaving.toLocaleString('en-IN')}.`;
      else tip = `Add health insurance under 80D for additional ₹${result.potentialSaving.toLocaleString('en-IN')} saving.`;
    }
    document.getElementById('simulatorText').innerText = tip;
  } else {
    sim.style.display = 'none';
  }
}

function toggleSavings() {
  const exp = document.getElementById('savingsExpandable');
  const icon = document.getElementById('expandIcon');
  exp.classList.toggle('open');
  icon.classList.toggle('open');
}

