/* ===== SCREEN ===== */
.kys-screen { display: none; width: 100%; max-width: 560px; }
.kys-screen.active { display: block; animation: kysScreenIn 0.5s ease forwards; }
@keyframes kysScreenIn { 0% { opacity: 0; transform: translateY(16px); } 100% { opacity: 1; transform: translateY(0); } }

/* ===== WIPE OVERLAY ===== */
.kys-wipe-overlay {
