<script>
// =====================
// TAX ENGINE
// =====================
const taxEngine = {
  calculate(data) {
    const salary = parseFloat(data.salary) || 0;
    const regime = data.regime || 'new';
    const ded80c = Math.min(parseFloat(data.deductions?.['80c']) || 0, 150000);
    const ded80d = Math.min(parseFloat(data.deductions?.['80d']) || 0, 25000);
    const hra    = parseFloat(data.deductions?.['hra']) || 0;

    let stdDed, taxable, tax;

    if (regime === 'new') {
      // New regime: Standard deduction ₹75,000 for salaried
      stdDed = Math.min(75000, salary);
      taxable = Math.max(salary - stdDed, 0);
      tax = this._computeNewRegime(taxable);
      // Rebate 87A: if income ≤ 7L, rebate up to ₹25,000
      if (taxable <= 700000) tax = Math.max(tax - 25000, 0);
    } else {
      // Old regime: standard deduction ₹50,000, 80C, 80D, HRA
      stdDed = Math.min(50000, salary);
      const totalDed = stdDed + ded80c + ded80d + hra;
      taxable = Math.max(salary - totalDed, 0);
      tax = this._computeOldRegime(taxable);
      // Rebate 87A: if income ≤ 5L, rebate up to ₹12,500
      if (taxable <= 500000) tax = Math.max(tax - 12500, 0);
    }

    const cess     = Math.round(tax * 0.04);
    const totalTax = tax + cess;

    // Potential saving if switch to optimal or use deductions
    let potentialSaving = 0;
    if (regime === 'old') {
      const remainingDed = (150000 - ded80c) + (25000 - ded80d);
      if (remainingDed > 0) {
        const newTaxableHypo = Math.max(taxable - remainingDed, 0);
        const newTaxHypo = this._computeOldRegime(newTaxableHypo);
        const newTaxHypoWithCess = newTaxHypo + Math.round(newTaxHypo * 0.04);
        potentialSaving = Math.max(totalTax - newTaxHypoWithCess, 0);
      }
    } else {
      // Compare with old regime w/ full deductions
      const hypoOldTaxable = Math.max(salary - 50000 - 150000 - 25000, 0);
      const hypoOldTax = this._computeOldRegime(hypoOldTaxable);
      const hypoOldTotal = hypoOldTax + Math.round(hypoOldTax * 0.04);
      potentialSaving = Math.max(totalTax - hypoOldTotal, 0);
      if (potentialSaving < 0) potentialSaving = 0;
    }

    return {
      grossIncome: salary,
      stdDeduction: stdDed,
      deductions: ded80c + ded80d + hra,
      taxableIncome: taxable,
      incomeTax: tax,
      cess,
      totalTax,
      potentialSaving,
      regime,
      slab: this._getSlab(taxable, regime),
    };
  },

  _computeNewRegime(taxable) {
    // FY 2025-26 New Regime slabs
    const slabs = [
      [300000, 0.00],
      [300000, 0.05],  // 3L-6L: 5%
      [300000, 0.10],  // 6L-9L: 10%
      [300000, 0.15],  // 9L-12L: 15%
      [300000, 0.20],  // 12L-15L: 20%
      [Infinity, 0.30] // >15L: 30%
    ];
    return this._slabCalc(taxable, slabs);
  },

  _computeOldRegime(taxable) {
    const slabs = [
      [250000, 0.00],
      [250000, 0.05],
      [500000, 0.20],
      [Infinity, 0.30]
    ];
    return this._slabCalc(taxable, slabs);
  },

  _slabCalc(income, slabs) {
    let tax = 0, rem = income;
    for (const [limit, rate] of slabs) {
      if (rem <= 0) break;
      const chunk = Math.min(rem, limit === Infinity ? rem : limit);
      tax += Math.round(chunk * rate);
      rem -= chunk;
    }
    return tax;
  },

  _getSlab(taxable, regime) {
    if (regime === 'new') {
      if (taxable <= 300000) return '0%';
      if (taxable <= 600000) return '5%';
      if (taxable <= 900000) return '10%';
      if (taxable <= 1200000) return '15%';
      if (taxable <= 1500000) return '20%';
      return '30%';
    } else {
      if (taxable <= 250000) return '0%';
      if (taxable <= 500000) return '5%';
      if (taxable <= 1000000) return '20%';
      return '30%';
    }
  },

  getRecommendedServices(state) {
    const services = [];
    const cat = state.category || 'individual';
    if (cat === 'individual') {
      services.push({ name: 'ITR-1 Filing', desc: 'For salaried individuals with one house property', price: 1499, timeline: '1–2 business days' });
      services.push({ name: 'ITR-2 Filing', desc: 'Capital gains, multiple sources, foreign assets', price: 2499, timeline: '2–3 business days' });
    } else if (cat === 'business') {
      services.push({ name: 'ITR-3 Filing', desc: 'Business & profession income, proprietorship', price: 3499, timeline: '3–5 business days' });
      services.push({ name: 'ITR-4 Filing', desc: 'Presumptive taxation under 44AD/44ADA', price: 1999, timeline: '2–3 business days' });
    } else {
      services.push({ name: 'NRI ITR-2', desc: 'Foreign income, DTAA relief, repatriation', price: 4999, timeline: '3–5 business days' });
      services.push({ name: 'NRI Advisory', desc: 'FEMA compliance & tax optimization planning', price: 7999, timeline: '5–7 business days' });
    }
    return services;
  }
};

