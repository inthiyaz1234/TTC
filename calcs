function buildResultDashboard(result) {
  const container = document.getElementById('resultContent');
  const name = appState.name || 'Taxpayer';
  const gross = result.grossIncome;
  const ded = result.deductions + result.stdDeduction;
  const taxable = result.taxableIncome;
  const incomeTax = result.incomeTax;
  const cess = result.cess;
  const total = result.totalTax;
  const savings = result.potentialSaving;

  const tdsMsg = appState.tds === 'no'
    ? 'Based on your income profile and applicable provisions under the Income Tax Act, filing an Income Tax Return is mandatory. Non-compliance may result in penalties or notices under Section 271F.'
    : 'Your tax liability has been computed in accordance with the applicable provisions of the Income Tax Act, 1961 for FY 2025–26. Additional optimization may be possible through structured tax planning with our CA team.';

  const services = taxEngine.getRecommendedServices(appState);
  const servicesHtml = services.map(s => `
    <div class="service-card">
      <div class="service-badge">${appState.category === 'nri' ? 'NRI' : 'ITR'}</div>
      <div class="service-title">${s.name}</div>
      <div class="service-desc">${s.desc}</div>
      <div class="service-price">₹${s.price.toLocaleString('en-IN')}</div>
      <div class="service-timeline">⏱ ${s.timeline}</div>
      <button class="service-cta" onclick="window.open('https://wa.me/917204058899?text=Hi, I need help filing ${encodeURIComponent(s.name)}', '_blank')">File Now →</button>
    </div>
  `).join('');

  container.innerHTML = `
    <!-- HERO -->
    <div class="result-hero">
      <div class="result-label">Total Tax Liability · FY ${appState.fy}</div>
      <div class="result-amount">₹${total.toLocaleString('en-IN')}</div>
      <div class="result-legal">As per applicable provisions of the Income Tax Act for FY 2025–26, ${name}'s estimated total tax liability is ₹${total.toLocaleString('en-IN')} under the ${appState.regime === 'new' ? 'new' : 'old'} tax regime.</div>
    </div>

    <!-- BREAKDOWN GRID -->
    <div class="breakdown-grid">
      <div class="breakdown-card">
        <div class="breakdown-icon">💰</div>
        <div class="breakdown-label">Gross Income</div>
        <div class="breakdown-value">₹${gross.toLocaleString('en-IN')}</div>
      </div>
      <div class="breakdown-card">
        <div class="breakdown-icon">📉</div>
        <div class="breakdown-label">Total Deductions</div>
        <div class="breakdown-value">₹${ded.toLocaleString('en-IN')}</div>
      </div>
      <div class="breakdown-card">
        <div class="breakdown-icon">📊</div>
        <div class="breakdown-label">Taxable Income</div>
        <div class="breakdown-value">₹${taxable.toLocaleString('en-IN')}</div>
      </div>
      <div class="breakdown-card">
        <div class="breakdown-icon">🧾</div>
        <div class="breakdown-label">Income Tax</div>
        <div class="breakdown-value">₹${incomeTax.toLocaleString('en-IN')}</div>
      </div>
      <div class="breakdown-card">
        <div class="breakdown-icon">📈</div>
        <div class="breakdown-label">Health & Ed. Cess</div>
        <div class="breakdown-value">₹${cess.toLocaleString('en-IN')}</div>
      </div>
      <div class="breakdown-card highlight">
        <div class="breakdown-icon">✅</div>
        <div class="breakdown-label">Net Tax Payable</div>
        <div class="breakdown-value">₹${total.toLocaleString('en-IN')}</div>
      </div>
    </div>

    <!-- AI INSIGHT -->
    <div class="kys-ai-summary">
      <div class="kys-ai-label"><div class="ai-dot"></div> AI Insight</div>
      <div class="kys-ai-text">${tdsMsg}</div>
    </div>

    <!-- SAVINGS HIGHLIGHT -->
    ${savings > 0 ? `
    <div class="savings-highlight">
      <div class="savings-icon">💡</div>
      <div class="savings-text">
        <div class="savings-text-title">You could save ₹${savings.toLocaleString('en-IN')}</div>
        <div class="savings-text-sub">By optimizing deductions & regime selection. Our CA team can help maximize your savings.</div>
      </div>
    </div>` : ''}

    <!-- SERVICES -->
    <div class="section-title">Recommended Services</div>
    <div class="service-grid">${servicesHtml}</div>

    <!-- FOOTER -->
    <div class="result-footer">
      <div class="trust-dots" style="justify-content:center;">
        <span>🔒 Secure</span>
        <div class="trust-dot-sep"></div>
        <span>Govt Compliant</span>
        <div class="trust-dot-sep"></div>
        <span>CA Assisted</span>
      </div>
      <div style="margin-top:12px;">This is an estimate. Actual liability may vary based on complete income details.</div>
    </div>

    <button class="kys-btn-primary" onclick="restart()" style="margin-bottom:20px;">← Calculate Again</button>
  `;
}

function restart() {
  // Reset state
  appState = { category: 'individual', salary: 800000, regime: 'new', tds: 'yes', deductions: {'80c':0,'80d':0,'hra':0}, fy: '2025-26', name: '', phone: '', email: '' };
  triggerWipe(() => showScreen('intro-screen'));
}

